# App
NODE_ENV=development
PORT=3000

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-opus-4-5

# LaunchDarkly
# SDK key (server-side) — from LD dashboard: Environments > your-env > SDK key
LD_SDK_KEY=sdk-your-key-here
# Client-side ID (browser) — from LD dashboard: Environments > your-env > Client-side ID
LD_CLIENT_SIDE_ID=your-client-side-id-here

# Demo simulation (these are now overridable via LD flags)
SIMULATE_LATENCY_MAX_MS=1200
SIMULATE_PAYMENT_FAILURE_RATE=0.05
